<section class="land-steps">
	<div class="wrapper">
		<header class="land-steps__header">
			<h2 class="land-steps__title">
				Этапы преображения Васюков

				<p class="land-steps__subtitle">
					Будущие источники обогащения васюкинцев
				</p>
			</h2>
		</header>

		<div class="land-steps__wrapper-carousel">
			<img src="/assets/pictures/landing/steps-airplane.webp" alt="steps-airplane" class="land-steps__airplane" />
			<div class="land-steps__carousel" data-steps>
				<div class="land-steps__viewport" data-steps-viewport>
					<div class="land-steps__track">
						<div class="land-steps__slide" data-steps-slide>
							<div class="land-steps__cell">
								<span class="land-steps__num">1</span>
								<span class="land-steps__value">Строительство железнодорожной магистрали Москва-Васюки</span>
							</div>
							<div class="land-steps__cell">
								<span class="land-steps__num">2</span>
								<span class="land-steps__value">Открытие фешенебельной гостиницы «Проходная пешка» и других небоскрёбов</span>
							</div>
						</div>
						<div class="land-steps__slide" data-steps-slide>
							<div class="land-steps__cell land-steps__cell--tall">
								<span class="land-steps__num">3</span>
								<span class="land-steps__value">Поднятие сельского хозяйства в радиусе на тысячу километров: производство овощей, фруктов, икры, шоколадных конфет</span>
							</div>
						</div>
						<div class="land-steps__slide" data-steps-slide>
							<div class="land-steps__cell">
								<span class="land-steps__num">4</span>
								<span class="land-steps__value">Строительство дворца для турнира</span>
							</div>
							<div class="land-steps__cell">
								<span class="land-steps__num">5</span>
								<span class="land-steps__value max-w-[300px]">Размещение гаражей для гостевого автотранспорта</span>
							</div>
						</div>
						<div class="land-steps__slide" data-steps-slide>
							<div class="land-steps__cell">
								<span class="land-steps__num">6</span>
								<span class="land-steps__value">Постройка сверхмощной радиостанции для передачи всему миру сенсационных результатов</span>
							</div>
						</div>
						<div class="land-steps__slide" data-steps-slide>
							<div class="land-steps__cell land-steps__cell--wide">
								<span class="land-steps__num">7</span>
								<span class="land-steps__value max-w-[446px]">Создание аэропорта «Большие Васюки» с регулярным отправлением почтовых самолётов и дирижаблей во все концы света, включая Лос-Анжелос и Мельбурн</span>
							</div>
						</div>
					</div>
				</div>

				<div class="land-steps__controls">
					<button type="button" class="btn-bubble" data-steps-prev aria-label="Предыдущий слайд"><div class="i-svg:chevron-left btn-bubble__chevron-icon"></div></button>
					<div class="land-steps__dots" data-steps-dots role="tablist"></div>
					<button type="button" class="btn-bubble" data-steps-next aria-label="Следующий слайд"><div class="i-svg:chevron-right btn-bubble__chevron-icon"></div></button>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const AUTOPLAY_INTERVAL = 4000
	const MOBILE_QUERY = '(max-width: 1261.98px)'

	const initSteps = (root: HTMLElement) => {
		const viewport = root.querySelector<HTMLElement>('[data-steps-viewport]')
		const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-steps-slide]'))
		const dotsRoot = root.querySelector<HTMLElement>('[data-steps-dots]')
		const prev = root.querySelector<HTMLButtonElement>('[data-steps-prev]')
		const next = root.querySelector<HTMLButtonElement>('[data-steps-next]')

		if (!viewport || !dotsRoot || slides.length === 0) return

		const track = slides[0].parentElement
		if (!track) return

		const cloneLast = slides[slides.length - 1].cloneNode(true) as HTMLElement
		const cloneFirst = slides[0].cloneNode(true) as HTMLElement
		;[cloneFirst, cloneLast].forEach((el) => {
			el.setAttribute('aria-hidden', 'true')
			el.removeAttribute('data-steps-slide')
			el.classList.add('land-steps__slide--clone')
		})
		track.insertBefore(cloneLast, slides[0])
		track.appendChild(cloneFirst)

		const slideIndex = new Map<HTMLElement, number>()
		slides.forEach((slide, i) => slideIndex.set(slide, i))
		slideIndex.set(cloneFirst, 0)
		slideIndex.set(cloneLast, slides.length - 1)

		const dots = slides.map((_, i) => {
			const dot = document.createElement('button')
			dot.type = 'button'
			dot.className = 'land-steps__dot'
			dot.setAttribute('role', 'tab')
			dot.setAttribute('aria-label', `Слайд ${i + 1}`)
			dotsRoot.appendChild(dot)
			return dot
		})

		let current = 0
		let pendingTarget: number | null = null

		const updateUI = () => {
			dots.forEach((d, i) => d.classList.toggle('is-active', i === current))
		}

		const slideWidth = () => viewport.clientWidth
		const physicalScroll = (logicalIndex: number) => slideWidth() * (logicalIndex + 1)

		const ensureRealPosition = () => {
			const sw = slideWidth()
			const total = slides.length
			if (viewport.scrollLeft < 1) {
				viewport.scrollTo({ left: physicalScroll(total - 1), behavior: 'auto' })
			} else if (viewport.scrollLeft > sw * (total + 1) - 1) {
				viewport.scrollTo({ left: physicalScroll(0), behavior: 'auto' })
			}
		}

		const goTo = (target: number, behavior: ScrollBehavior = 'smooth') => {
			ensureRealPosition()
			current = ((target % slides.length) + slides.length) % slides.length
			pendingTarget = current
			let scrollPos: number
			if (target === slides.length) scrollPos = physicalScroll(slides.length)
			else if (target === -1) scrollPos = physicalScroll(-1)
			else scrollPos = physicalScroll(current)
			viewport.scrollTo({ left: scrollPos, behavior })
			updateUI()
		}

		updateUI()

		const mq = window.matchMedia(MOBILE_QUERY)
		let teardown: (() => void) | null = null

		const setupCarousel = () => {
			teardown?.()
			teardown = null

			if (!mq.matches) return

			viewport.scrollTo({ left: physicalScroll(current), behavior: 'auto' })

			const ac = new AbortController()
			const { signal } = ac

			let intervalId = 0
			const tick = () => goTo(current + 1, 'smooth')
			const restartTimer = () => {
				clearInterval(intervalId)
				intervalId = window.setInterval(tick, AUTOPLAY_INTERVAL)
			}

			let scrollDebounce = 0
			viewport.addEventListener(
				'scroll',
				() => {
					clearTimeout(scrollDebounce)
					scrollDebounce = window.setTimeout(ensureRealPosition, 100)
				},
				{ signal },
			)

			prev?.addEventListener(
				'click',
				() => {
					goTo(current - 1)
					restartTimer()
				},
				{ signal },
			)
			next?.addEventListener(
				'click',
				() => {
					goTo(current + 1)
					restartTimer()
				},
				{ signal },
			)
			dots.forEach((dot, i) => {
				dot.addEventListener(
					'click',
					() => {
						goTo(i)
						restartTimer()
					},
					{ signal },
				)
			})

			const observer = new IntersectionObserver(
				(entries) => {
					const visible = entries.filter((e) => e.isIntersecting)
					if (visible.length === 0) return
					const top = visible.reduce((a, b) => (a.intersectionRatio > b.intersectionRatio ? a : b))
					const newCurrent = slideIndex.get(top.target as HTMLElement)
					if (newCurrent === undefined) return
					if (pendingTarget !== null) {
						if (newCurrent === pendingTarget) pendingTarget = null
						return
					}
					if (newCurrent === current) return
					current = newCurrent
					updateUI()
					restartTimer()
				},
				{ root: viewport, threshold: [0.5, 0.75, 1] },
			)
			slideIndex.forEach((_, el) => observer.observe(el))

			viewport.addEventListener(
				'pointerdown',
				() => {
					pendingTarget = null
					restartTimer()
				},
				{ signal },
			)

			window.addEventListener(
				'resize',
				() => {
					viewport.scrollTo({ left: physicalScroll(current), behavior: 'auto' })
				},
				{ signal },
			)

			intervalId = window.setInterval(tick, AUTOPLAY_INTERVAL)

			teardown = () => {
				ac.abort()
				observer.disconnect()
				clearInterval(intervalId)
				clearTimeout(scrollDebounce)
			}
		}

		const onMqChange = () => setupCarousel()
		mq.addEventListener('change', onMqChange)
		setupCarousel()

		window.addEventListener(
			'pagehide',
			() => {
				teardown?.()
				teardown = null
				mq.removeEventListener('change', onMqChange)
			},
			{ once: true },
		)
	}

	document.querySelectorAll<HTMLElement>('[data-steps]').forEach(initSteps)
</script>
